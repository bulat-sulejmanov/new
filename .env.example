DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-before-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Локальный PostgreSQL для разработки
DB_ENGINE=django.db.backends.postgresql
DB_NAME=tehsnab_warehouse
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=True
DB_CONNECT_TIMEOUT=3
DB_SSL_REQUIRE=False

# Вариант одной строкой (для хостинга можно использовать только DATABASE_URL)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/tehsnab_warehouse

# Для production-примера:
# DJANGO_ENV=production
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-domain.ru,www.your-domain.ru
# CSRF_TRUSTED_ORIGINS=https://your-domain.ru,https://www.your-domain.ru
